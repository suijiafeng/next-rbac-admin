// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id         Int        @id @default(autoincrement())
  username   String     @unique
  password   String
  authVersion Int       @default(0)
  nickname   String?
  email      String?    @unique
  avatar     String?    // 头像 URL（/avatars/{userId}.{ext} 或外部链接）
  status     Int        @default(1) // 1:启用 0:禁用
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  userRoles  UserRole[]

  @@map("users")
}


model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique // 角色标识，例如 admin、user、super_admin
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id              Int              @id @default(autoincrement())
  code            String           @unique // 权限编码，例如 user.view
  name            String           // 权限名称，例如 查看用户
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  @@map("permissions")
}

model UserRole {
  id        Int      @id @default(autoincrement())
  userId    Int
  roleId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("system_setting")
}

model AuditLog {
  id              Int      @id @default(autoincrement())
  actorId         Int?
  actorUsername   String
  action          String   // role.grant_admin / role.revoke_admin / user.suspend / user.unsuspend / user.reset_password / settings.update
  targetType      String   // user / settings
  targetId        String?
  targetLabel     String?
  detail          String?  // JSON 字符串
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

/// 意见反馈：数据自底层向上层流动
/// 提交者只能是 USER / ADMIN；可见者为「严格高于」提交者角色的人
model Feedback {
  id                Int      @id @default(autoincrement())
  submitterId       Int
  submitterUsername String
  submitterNickname String?
  submitterRole     String   // USER / ADMIN —— 决定谁能看到
  type              String   // bug / feature / experience / other
  priority          String   // low / medium / high
  title             String
  content           String
  contact           String?
  satisfaction      Int?
  createdAt         DateTime @default(now())

  reads             FeedbackRead[]

  @@index([submitterRole])
  @@index([createdAt])
  @@map("feedbacks")
}

/// 登录/注册失败次数追踪（数据库持久化，多实例/Serverless 环境下安全可靠）
/// key 可以是用户名（登录限流）或 IP 地址（注册限流）
model LoginAttempt {
  id        Int      @id @default(autoincrement())
  key       String   @unique // 用户名 或 "ip:x.x.x.x"
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
  @@map("login_attempts")
}

/// 每个接收者对某条反馈的已读记录（未读角标按接收者维度计算）
model FeedbackRead {
  id         Int      @id @default(autoincrement())
  feedbackId Int
  userId     Int
  createdAt  DateTime @default(now())

  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@unique([feedbackId, userId])
  @@index([userId])
  @@map("feedback_reads")
}

/// 公告：由 ADMIN/SUPER_ADMIN 发布，展示在仪表盘
model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  publisherId Int
  publisherUsername String
  level       String   @default("info") // 等级：info 普通 / warning 重要 / critical 紧急
  active      Boolean  @default(true)   // 是否生效
  startsAt    DateTime @default(now())  // 生效时间
  expiresAt   DateTime?                 // 过期时间（null 表示永不过期）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
  @@index([startsAt])
  @@map("announcements")
}
/// 变更请求：敏感角色变更先提案，审批通过后才生效（治理升级）
/// 沿用本项目"日志/流程类表反范式存 actorId + username、不建 FK"的风格
model ChangeRequest {
  id                Int       @id @default(autoincrement())
  type              String    // ASSIGN_ROLE
  status            String    @default("PENDING") // PENDING / APPROVED / REJECTED
  targetUserId      Int
  targetUsername    String
  fromRole          String
  toRole            String
  reason            String?
  risks             String?   // JSON 字符串：[{ level, text }]
  requesterId       Int
  requesterUsername String
  decidedById       Int?
  decidedByUsername String?
  decidedAt         DateTime?
  createdAt         DateTime  @default(now())

  @@index([status])
  @@index([createdAt])
  @@map("change_requests")
}

/// 临时授权：把普通用户临时提升为管理员，到期由系统自动回收
model TempGrant {
  id                Int       @id @default(autoincrement())
  userId            Int
  username          String
  grantedRole       String    // ADMIN
  fromRole          String
  condition         String?   // ABAC 约束(JSON)：如「仅工作时间」；null 表示无约束
  reason            String?
  status            String    @default("ACTIVE") // ACTIVE / EXPIRED / REVOKED
  grantedById       Int
  grantedByUsername String
  grantedAt         DateTime  @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  revokedByUsername String?

  @@index([status])
  @@index([expiresAt])
  @@map("temp_grants")
}
